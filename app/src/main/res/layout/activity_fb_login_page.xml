<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".FbLoginPage"
    android:layout_marginTop="25dp"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:background="#0F212E"
    >
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="20dp"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        >


        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginTop="60dp"
            android:paddingTop="10dp"
            android:src="@drawable/ic_roundfb" />

        <EditText
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:hint="Mobile number or email address"
        android:layout_marginTop="50dp"
        android:background="@drawable/input_field_shape"
        android:textColor="@android:color/black"
        android:textColorHint="#777777"
        android:padding="15dp"
        android:inputType="textEmailAddress"
        />
    <EditText
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:hint="Password"
        android:layout_marginTop="20dp"
        android:background="@drawable/input_field_shape"
        android:textColor="@android:color/black"
        android:textColorHint="#777777"
        android:padding="15dp"
        android:inputType="number"
        />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:text="Log in"
            android:gravity="center_horizontal"
            android:layout_marginTop="20dp"
            android:paddingTop="15dp"
            android:background="@drawable/button_shape"
            android:backgroundTint="@null"
            android:textColor="@android:color/white"
            />
        
        <TextView
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Forgotten Password?"
            android:textColor="@color/white"
            android:gravity="center_horizontal"
            android:paddingTop="15dp"
            />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:text="Create new account"
            android:gravity="center_horizontal"

            android:paddingTop="15dp"
            android:background="@drawable/create_new_account"
            android:backgroundTint="@null"
            android:textColor="#2364E2"
            />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_horizontal"
            android:paddingTop="10dp"
            >
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_meta"
                />
            <TextView
                android:layout_width="40dp"
                android:layout_marginTop="10dp"
                android:layout_height="wrap_content"
                android:textSize="15dp"
                android:text="Meta"
                android:textColor="@color/white"
                />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>